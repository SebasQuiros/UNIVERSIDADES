# ================================================================
#  CONTAFÁCIL SQ — Variables de Entorno
#  Copia este archivo a .env y ajusta los valores
#  cp .env.example .env
# ================================================================

# ── Base de datos ──────────────────────────────────────────────
POSTGRES_DB=contafacil
POSTGRES_USER=contafacil
POSTGRES_PASSWORD=contafacil2026
POSTGRES_PORT=5432

# URL completa para Prisma (generada automáticamente en Docker)
DATABASE_URL=postgresql://contafacil:contafacil2026@database:5432/contafacil

# Para desarrollo local sin Docker (apunta a localhost)
# DATABASE_URL=postgresql://contafacil:contafacil2026@localhost:5432/contafacil

# ── JWT / Autenticación ────────────────────────────────────────
# IMPORTANTE: Cambiar en producción — mínimo 32 caracteres aleatorios
JWT_SECRET=contafacil_jwt_secret_change_in_production_min32chars
JWT_EXPIRES=15m

REFRESH_SECRET=contafacil_refresh_secret_change_in_production_min32chars
REFRESH_EXPIRES=7d

# ── Servidor ───────────────────────────────────────────────────
BACKEND_PORT=3001
FRONTEND_PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost

# ── Redis ──────────────────────────────────────────────────────
# Dejar vacío en desarrollo. En producción cambiar a contraseña segura:
# REDIS_PASSWORD=una_contraseña_fuerte_aqui
# REDIS_URL=redis://:una_contraseña_fuerte_aqui@redis:6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# URL pública del API (usada por el frontend)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Email / SMTP ───────────────────────────────────────────────
# Para Gmail: usar App Password (no la contraseña normal)
# Habilitar en: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password
SMTP_FROM=CONTAFÁCIL SQ <noreply@tudominio.cr>

# ── Archivos generados ─────────────────────────────────────────
# Ruta donde se guardan PDFs e XMLs generados
UPLOADS_PATH=./uploads
PDF_PATH=./uploads/pdfs
XML_PATH=./uploads/xmls
