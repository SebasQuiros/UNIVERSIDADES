# ================================================================
#  CONTAFÁCIL SQ — Variables de entorno para PRODUCCIÓN
#  Copia este archivo como .env en la raíz del proyecto y
#  reemplaza TODOS los valores marcados con CHANGE_ME.
#
#  Genera secretos seguros con:
#    node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ================================================================

# ── Base de datos PostgreSQL ─────────────────────────────────────
POSTGRES_DB=contafacil_prod
POSTGRES_USER=contafacil_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_20_CHARS
POSTGRES_PORT=5432

# ── JWT (mínimo 32 caracteres, usar el comando de arriba) ────────
JWT_SECRET=CHANGE_ME_96_HEX_CHARS_USE_CRYPTO_RANDOMBYTES
REFRESH_SECRET=CHANGE_ME_DIFFERENT_96_HEX_CHARS_USE_CRYPTO
JWT_EXPIRES=15m
REFRESH_EXPIRES=7d

# ── Aplicación ───────────────────────────────────────────────────
NODE_ENV=production
BACKEND_PORT=3001
FRONTEND_PORT=3000

# Dominio de producción (sin slash final)
# Ejemplo: https://contafacil.ucr.ac.cr
CORS_ORIGIN=https://TU_DOMINIO.com,http://localhost
NEXT_PUBLIC_API_URL=https://TU_DOMINIO.com
BACKEND_URL=http://backend:3001

# ── Redis (no cambiar si usas docker-compose) ────────────────────
REDIS_URL=redis://redis:6379

# ── OAuth Google (opcional) ──────────────────────────────────────
# Crear en https://console.cloud.google.com/apis/credentials
# URI de redirección autorizada: https://TU_DOMINIO.com/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth Microsoft (opcional) ───────────────────────────────────
# Crear en https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# URI de redirección autorizada: https://TU_DOMINIO.com/api/v1/auth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Inteligencia Artificial (opcional) ───────────────────────────
# Obtener en https://console.anthropic.com/
# Si no se configura, el módulo AI queda deshabilitado.
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── Notas de seguridad ───────────────────────────────────────────
# 1. NUNCA subas el archivo .env a git (ya está en .gitignore).
# 2. JWT_SECRET y REFRESH_SECRET deben ser valores DISTINTOS.
# 3. POSTGRES_PASSWORD debe tener al menos 20 caracteres.
# 4. En un VPS, guarda el .env con permisos 600: chmod 600 .env
