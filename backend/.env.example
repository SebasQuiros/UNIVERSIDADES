# ================================================================
#  CONTAFÁCIL SQ — Backend Environment Variables
#  Copy to .env and fill in real values before running.
#  NEVER commit .env to version control.
# ================================================================

# ── Database ───────────────────────────────────────────────────
POSTGRES_DB=contafacil
POSTGRES_USER=contafacil
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_PORT=5432

# Full connection URL used by Prisma
# Docker:     postgresql://contafacil:PASSWORD@db:5432/contafacil
# Local:      postgresql://contafacil:PASSWORD@localhost:5432/contafacil
DATABASE_URL=postgresql://contafacil:CHANGE_ME@db:5432/contafacil

# PgBouncer (if used in production)
# DATABASE_URL=postgresql://contafacil:CHANGE_ME@pgbouncer:6432/contafacil?pgbouncer=true

# ── JWT / Auth ─────────────────────────────────────────────────
# REQUIRED: generate with:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_min_32_random_chars
JWT_EXPIRES=15m

# REQUIRED: generate with:  openssl rand -hex 32
REFRESH_SECRET=CHANGE_ME_min_32_random_chars_different_from_jwt
REFRESH_EXPIRES=7d

# ── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production          # development | production
CORS_ORIGIN=https://yourdomain.cr   # comma-separated for multiple origins
FRONTEND_URL=https://yourdomain.cr

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379
# Leave blank for dev without auth:
# REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── Email / SMTP ───────────────────────────────────────────────
# Gmail example — use an App Password (not your account password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.cr
SMTP_PASS=CHANGE_ME_app_password
SMTP_FROM=CONTAFÁCIL SQ <noreply@yourdomain.cr>

# ── AI assistant ────────────────────────────────────────────────
# Leave blank to disable the AI assistant
ANTHROPIC_API_KEY=

# ── File storage ────────────────────────────────────────────────
# Local paths — replace with S3/MinIO URLs in production
UPLOADS_PATH=./uploads
PDF_PATH=./uploads/pdfs
XML_PATH=./uploads/xmls
# TODO(production): Configure object storage instead of local disk:
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
