  description String
  quantity    Decimal  @db.Decimal(15,3)
  unit        String   @default("Unid")
  unitPrice   Decimal  @map("unit_price") @db.Decimal(15,2)
  discount    Decimal  @default(0) @db.Decimal(15,2)
  taxRate     Decimal  @map("tax_rate")   @db.Decimal(5,2)
  taxAmount   Decimal  @map("tax_amount") @db.Decimal(15,2)
  subtotal    Decimal  @db.Decimal(15,2)
  total       Decimal  @db.Decimal(15,2)
  cabysCode   String?  @map("cabys_code")  // 13 dígitos

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model ElectronicDocument {
  id           String    @id @default(uuid()) @db.Uuid
  invoiceId    String    @unique @map("invoice_id") @db.Uuid
  clave        String                              // 50 dígitos
  consecutive  String
  xmlContent   String    @map("xml_content") @db.Text
  status       String    @default("PENDING")       // PENDING, ACCEPTED, REJECTED
