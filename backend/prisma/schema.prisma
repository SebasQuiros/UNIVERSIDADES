model Invoice {
  id                    String        @id @default(uuid()) @db.Uuid
  companyId             String        @map("company_id") @db.Uuid
  clientId              String?       @map("client_id")  @db.Uuid
  clientName            String        @map("client_name")
  clientIdentification  String        @map("client_identification")
  consecutiveNumber     String        @map("consecutive_number")
  clave                 String?
  type                  InvoiceType   @default(FE)
  saleCondition         SaleCondition @default(CASH) @map("sale_condition")
  paymentMethod         PaymentMethod @default(CASH) @map("payment_method")
  currency              String        @default("CRC")
  exchangeRate          Decimal       @default(1)    @map("exchange_rate") @db.Decimal(10,4)
  status                InvoiceStatus @default(DRAFT)
  haciendaStatus        String        @default("PENDING") @map("hacienda_status")
  subtotal              Decimal       @default(0) @db.Decimal(15,2)
  discount              Decimal       @default(0) @db.Decimal(15,2)
  tax                   Decimal       @default(0) @db.Decimal(15,2)
  total                 Decimal       @default(0) @db.Decimal(15,2)
  paidAmount            Decimal       @default(0) @map("paid_amount") @db.Decimal(15,2)
  balanceDue            Decimal       @default(0) @map("balance_due") @db.Decimal(15,2)
  xml                   String?       @db.Text
  pdfUrl                String?       @map("pdf_url")
  haciendaResponse      Json?         @map("hacienda_response")
  haciendaMessage       String?       @map("hacienda_message") @db.Text
  notes                 String?
  issueDate             DateTime      @map("issue_date")
  issuedAt              DateTime?     @map("issued_at")
  createdById           String        @map("created_by_id") @db.Uuid
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt      @map("updated_at")

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client              Client?              @relation(fields: [clientId], references: [id])
  createdBy           User                 @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  items               InvoiceItem[]
  electronicDocument  ElectronicDocument?
  journalEntries      JournalEntry[]
  invoicePayments     InvoicePayment[]
  arPayments          ArPayment[]
  accountReceivable   AccountReceivable?

  @@unique([companyId, consecutiveNumber])
  @@index([companyId])
  @@index([clientId])
  @@index([status])
  @@index([haciendaStatus])
  @@index([createdById])
  @@index([issueDate(sort: Desc)])
  @@index([companyId, status])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
