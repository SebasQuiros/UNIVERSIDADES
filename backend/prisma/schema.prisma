  totalDebits    Decimal  @db.Decimal(15,2) @map("total_debits")
  closingBalance Decimal  @db.Decimal(15,2) @map("closing_balance")
  status         String   @default("PENDING")  // PENDING, IN_PROGRESS, COMPLETED
  reconciledAt   DateTime? @map("reconciled_at")
