// ================================================================
//  BLOQUE 7 — INVENTARIO
// ================================================================

model ProductCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")

  products Product[]

  @@map("product_categories")
}

model Product {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id")  @db.Uuid
  categoryId   String?  @map("category_id") @db.Uuid
  name         String
  description  String?
  sku          String?
  cabysCode    String?  @map("cabys_code")  // 13 dígitos — obligatorio para facturación CR
  cabysDesc    String?  @map("cabys_desc")  // Descripción desde catálogo CABYS
  price        Decimal  @db.Decimal(15,2)
  cost         Decimal  @default(0) @db.Decimal(15,2)
  taxRate      Decimal  @default(13) @map("tax_rate") @db.Decimal(5,2)
  // Tasas válidas CR: 0, 1, 2, 4, 8, 13
  stock        Decimal  @default(0) @db.Decimal(15,3)
  minStock     Decimal  @default(0) @map("min_stock") @db.Decimal(15,3)
  unit         String   @default("Unid")
  isService    Boolean  @default(false) @map("is_service")
  // Fase 2: si trackInventory=true, las ventas consumen lotes FIFO y registran COGS.
  // Para servicios siempre debería ser false (validado en service layer).
  trackInventory Boolean @default(true) @map("track_inventory")
  isActive     Boolean  @default(true)  @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category     ProductCategory?     @relation(fields: [categoryId], references: [id])
  invoiceItems InvoiceItem[]
  movements    InventoryMovement[]
  lots         InventoryLot[]

  @@index([companyId])
  @@index([cabysCode])
  @@map("products")
}

model InventoryMovement {
  id            String       @id @default(uuid()) @db.Uuid
  productId     String       @map("product_id") @db.Uuid
  companyId     String       @map("company_id") @db.Uuid
  type          MovementType
  quantity      Decimal      @db.Decimal(15,3)  // negativo = salida
  unitCost      Decimal?     @map("unit_cost") @db.Decimal(15,2)
  // Fase 2: totalCost almacena qty * unitCost para auditoría de COGS sin recalc.
  totalCost     Decimal?     @map("total_cost") @db.Decimal(15,2)
  // Fase 2: lotId apunta al lote consumido (SALE) o creado (PURCHASE/INITIAL).
  lotId         String?      @map("lot_id")     @db.Uuid
  referenceId   String?      @map("reference_id") @db.Uuid  // invoice_id u otro
  referenceType String?      @map("reference_type")
  balanceAfter  Decimal      @map("balance_after") @db.Decimal(15,3)
  notes         String?
  createdById   String       @map("created_by") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at")

  product Product       @relation(fields: [productId], references: [id])
  lot     InventoryLot? @relation(fields: [lotId], references: [id])

  @@index([productId])
  @@index([companyId])
  @@index([lotId])
  @@map("inventory_movements")
}

// ── InventoryLot (Fase 2 — FIFO) ────────────────────────────────
//
// Cada compra (o stock inicial) crea un lote con su qty y costo unitario.
// Las ventas consumen lotes ordenados por receivedAt asc (FIFO).
// El índice compuesto [productId, qtyRemaining, receivedAt] está pensado
// para que el query de consumo sea sub-milisegundo aún con miles de lotes:
//   WHERE productId = ? AND qtyRemaining > 0
//   ORDER BY receivedAt ASC
model InventoryLot {
  id           String   @id @default(uuid()) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  qtyOriginal  Decimal  @map("qty_original")  @db.Decimal(15,3)
  qtyRemaining Decimal  @map("qty_remaining") @db.Decimal(15,3)
  unitCost     Decimal  @map("unit_cost")     @db.Decimal(15,2)
  source       String   // 'PURCHASE' | 'INITIAL' | 'ADJUSTMENT'
  sourceId     String?  @map("source_id")     // UUID del documento origen (string para no acoplar tipo)
  receivedAt   DateTime @default(now()) @map("received_at")
  createdAt    DateTime @default(now()) @map("created_at")

  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  movements InventoryMovement[]

  @@index([productId, qtyRemaining, receivedAt])
  @@index([companyId])
  @@index([source, sourceId])
  @@map("inventory_lots")
}

// ================================================================
//  BLOQUE 8 — FACTURACIÓN ELECTRÓNICA CR
