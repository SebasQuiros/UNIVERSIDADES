//
//  Modelos: 26
//  Base de datos: PostgreSQL 15
// ================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================================================
//  ENUMS
// ================================================================

enum Role {
  SUPERADMIN
  ADMIN
  TEACHER
  STUDENT
}

enum OAuthProvider {
  LOCAL
  GOOGLE
  MICROSOFT
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  ACCEPTED
  REJECTED
  CANCELLED
}

enum InvoiceType {
  FE   // Factura Electrónica
  NC   // Nota de Crédito
  ND   // Nota de Débito
  TE   // Tiquete Electrónico
}

enum SaleCondition {
  CASH        // 01 - Contado
  CREDIT      // 02 - Crédito
  CONSIGNMENT // 03 - Consignación
  APART       // 04 - Apartado
  LEASE       // 05 - Arrendamiento con opción de compra
  OTHER       // 99 - Otros
}

enum PaymentMethod {
  CASH        // 01 - Efectivo
  CARD        // 02 - Tarjeta
  CHECK       // 03 - Cheque
  TRANSFER    // 04 - Transferencia
  OTHER       // 99 - Otros
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REVERSED
}

enum PeriodType {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum PeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum JournalSource {
  MANUAL
  AUTO_INVOICE
  AUTO_PAYMENT
  AUTO_PURCHASE
  ADJUSTMENT
  PERIOD_CLOSING
  OPENING_BALANCE
  REVERSAL
}

/// Estado de un asiento contable:
///   CONFIRMED — final, afecta saldos y reportes (default).
///   PENDING   — generado por la engine en modo HYBRID, esperando aprobación; NO afecta saldos.
///   REJECTED  — descartado por el usuario; conserva trazabilidad pero se excluye de saldos.
enum JournalEntryStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum MovementType {
  SALE
  PURCHASE
  ADJUSTMENT
  RETURN
  INITIAL_STOCK
}

enum ExerciseStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum ExerciseDifficulty {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum ExerciseType {
  FULL_CYCLE
  JOURNAL_ONLY
  INVOICING_ONLY
  INVENTORY_ONLY
}

// ── Fase 1 (Config Engine + Multi-company) ──────────────────────
enum CompanyMode {
  INDIVIDUAL
  GROUP
}

enum CompanyRole {
  OWNER
  MEMBER
}

enum TrackingEvent {
  EXERCISE_OPENED
  EXERCISE_RESUMED
  INVOICE_CREATED
  INVOICE_ISSUED
  JOURNAL_ENTRY_SAVED
  REPORT_VIEWED
  EXERCISE_SUBMITTED
  CLIENT_CREATED
  PRODUCT_CREATED
}

enum NotificationType {
  INFO
  WARNING
  EXERCISE_ASSIGNED
  EXERCISE_DUE
  GRADED
  SYSTEM
}

// ================================================================
//  BLOQUE 1 — PLANES Y UNIVERSIDADES
// ================================================================

model Plan {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  maxStudents Int      @default(50)   @map("max_students")
  maxCourses  Int      @default(5)    @map("max_courses")
  priceUsd    Decimal  @default(0)    @map("price_usd")    @db.Decimal(10,2)
  isActive    Boolean  @default(true) @map("is_active")
  features    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  universities University[]

  @@map("plans")
}

model University {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  shortName   String?  @map("short_name")
  country     String   @default("Costa Rica")
  website     String?
  logoUrl     String?  @map("logo_url")
  planId      String?  @map("plan_id") @db.Uuid
  maxStudents Int      @default(50)   @map("max_students")
  isActive    Boolean  @default(true) @map("is_active")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt     @map("updated_at")

  plan    Plan?    @relation(fields: [planId], references: [id])
  users   User[]
  courses Course[]
  competencies Competency[]

  @@map("universities")
}

// ================================================================
//  BLOQUE 2 — USUARIOS Y SESIONES
// ================================================================

model User {
  id                 String        @id @default(uuid()) @db.Uuid
  name               String
  email              String        @unique
  passwordHash       String?       @map("password_hash")
  role               Role          @default(STUDENT)
  universityId       String?       @map("university_id") @db.Uuid
  avatarUrl          String?       @map("avatar_url")
  oauthProvider      OAuthProvider @default(LOCAL) @map("oauth_provider")
  oauthId            String?       @map("oauth_id")
  isActive           Boolean       @default(true) @map("is_active")
  emailVerified      Boolean       @default(false) @map("email_verified")
  emailVerifyToken        String?  @map("email_verify_token")
  emailVerifyTokenExpires DateTime? @map("email_verify_token_expires")
  mustChangePassword Boolean       @default(false) @map("must_change_password")
  // ── 2FA TOTP (RFC 6238) ──────────────────────────────────
  totpSecret         String?       @map("totp_secret")     // base32 secret
  totpEnabled        Boolean       @default(false) @map("totp_enabled")
  resetToken         String?       @map("reset_token")
  resetTokenExpires  DateTime?     @map("reset_token_expires")
  lastLogin          DateTime?     @map("last_login")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt      @map("updated_at")

  university         University?        @relation(fields: [universityId], references: [id])
  sessions           Session[]
  teacherCourses     Course[]           @relation("TeacherCourses")
  enrollments        Enrollment[]
  exercises          Exercise[]         @relation("TeacherExercises")
  attempts           ExerciseAttempt[]
  companies          Company[]
  companyMemberships CompanyMembership[]
  gradedAttempts     ExerciseAttempt[]  @relation("GradedBy")
  journalEntries     JournalEntry[]
  invoicesCreated    Invoice[]          @relation("InvoiceCreatedBy")
  notifications      Notification[]
  activityLogs       ActivityLog[]
  sessionTrackings   SessionTracking[]
  taxDeclarations    TaxDeclaration[]

  @@unique([oauthProvider, oauthId])
  @@index([email])
  @@index([universityId])
  @@index([role])
  @@map("users")
}

model Session {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  token        String    @unique           // JWT ID (jti)
  refreshToken String    @unique           @map("refresh_token")
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  deviceInfo   String?   @map("device_info")
  isActive     Boolean   @default(true)   @map("is_active")
  expiresAt    DateTime  @map("expires_at")
  lastUsedAt   DateTime  @default(now())  @map("last_used_at")
  revokedAt    DateTime? @map("revoked_at")
  revokedBy    String?   @map("revoked_by") @db.Uuid
  createdAt    DateTime  @default(now())  @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([refreshToken])
  @@map("sessions")
}

// ================================================================
//  BLOQUE 3 — SISTEMA ACADÉMICO
// ================================================================

model Course {
  id           String   @id @default(uuid()) @db.Uuid
  universityId String   @map("university_id") @db.Uuid
  teacherId    String   @map("teacher_id")    @db.Uuid
  name         String
  description  String?
  code         String?
  period       String?  // "2026-I", "2026-II"
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  university  University   @relation(fields: [universityId], references: [id])
  teacher     User         @relation("TeacherCourses", fields: [teacherId], references: [id])
  enrollments Enrollment[]
  exercises   Exercise[]

  @@index([universityId])
  @@index([teacherId])
  @@map("courses")
}

model Enrollment {
  id         String   @id @default(uuid()) @db.Uuid
  courseId   String   @map("course_id")  @db.Uuid
  studentId  String   @map("student_id") @db.Uuid
  isActive   Boolean  @default(true) @map("is_active")
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@index([courseId])
  @@index([studentId])
  @@map("enrollments")
}

model Exercise {
  id           String             @id @default(uuid()) @db.Uuid
  courseId     String             @map("course_id")  @db.Uuid
  teacherId    String             @map("teacher_id") @db.Uuid
  title        String
  description  String?
  instructions String?            @db.Text
  difficulty   ExerciseDifficulty @default(BASIC)
  type         ExerciseType       @default(FULL_CYCLE)
  maxScore     Decimal            @default(100) @map("max_score") @db.Decimal(5,2)
  dueDate      DateTime?          @map("due_date")
  isPublished  Boolean            @default(false) @map("is_published")
  isArchived   Boolean            @default(false) @map("is_archived")
  settings     Json               @default("{}")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt      @map("updated_at")

  course       Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher      User                 @relation("TeacherExercises", fields: [teacherId], references: [id])
  rubrics      ExerciseRubric[]
  attempts     ExerciseAttempt[]
  config       ExerciseConfig?
  companies    Company[]            @relation("ExerciseCompanies")
  competencies ExerciseCompetency[]

  @@index([courseId])
  @@index([teacherId])
  @@index([isPublished])
  @@map("exercises")
}

// ── ExerciseConfig (Fase 1) ─────────────────────────────────────
//
// Configuración por plantilla de Ejercicio. Toda Company y Attempt
// derivado de ese Ejercicio comparte esta config. El profesor la
// modifica mientras Exercise.isPublished = false; al publicar
// queda BLOQUEADA para garantizar consistencia académica.
//
// Defaults reflejan el comportamiento histórico del sistema:
// journal/ledger/trialBalance/AR/AP en true (es como funciona hoy).
// inventory e inter-company en false porque son features nuevos opt-in.
model ExerciseConfig {
  id           String      @id @default(uuid()) @db.Uuid
  exerciseId   String      @unique @map("exercise_id") @db.Uuid
  companyMode  CompanyMode @default(INDIVIDUAL) @map("company_mode")

  autoJournal                      Boolean @default(true)  @map("auto_journal")
  autoLedger                       Boolean @default(true)  @map("auto_ledger")
  autoTrialBalance                 Boolean @default(true)  @map("auto_trial_balance")
  autoAR                           Boolean @default(true)  @map("auto_ar")
  autoAP                           Boolean @default(true)  @map("auto_ap")
  autoInventory                    Boolean @default(false) @map("auto_inventory")
  autoTransactionsBetweenCompanies Boolean @default(false) @map("auto_inter_company")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@map("exercise_configs")
}

model ExerciseRubric {
  id            String   @id @default(uuid()) @db.Uuid
  exerciseId    String   @map("exercise_id") @db.Uuid
  competencyId  String?  @map("competency_id") @db.Uuid   // opcional: evidencia de grano fino
  criterion     String                           // 'min_invoices', 'balanced_sheet', etc.
  description   String
  expectedValue String?  @map("expected_value")
  points        Decimal  @db.Decimal(5,2)
  order         Int      @default(0)

  exercise   Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  competency Competency? @relation(fields: [competencyId], references: [id])

  @@index([exerciseId])
  @@index([competencyId])
  @@map("exercise_rubrics")
}

model ExerciseAttempt {
  id          String         @id @default(uuid()) @db.Uuid
  exerciseId  String         @map("exercise_id") @db.Uuid
  studentId   String         @map("student_id")  @db.Uuid
  status      ExerciseStatus @default(NOT_STARTED)
  score       Decimal?       @db.Decimal(5,2)
  maxScore    Decimal        @default(100) @map("max_score") @db.Decimal(5,2)
  feedback    String?        @db.Text
  gradedById  String?        @map("graded_by") @db.Uuid
  gradedAt    DateTime?      @map("graded_at")
  startedAt   DateTime?      @map("started_at")
  submittedAt DateTime?      @map("submitted_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt      @map("updated_at")

  exercise         Exercise          @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  student          User              @relation(fields: [studentId], references: [id])
  gradedBy         User?             @relation("GradedBy", fields: [gradedById], references: [id])
  company          Company?
  purchaseInvoices PurchaseInvoice[]
  activityTracking ActivityTracking[]
  sessionTracking  SessionTracking[]
  studentProgress  StudentProgress?

  @@unique([exerciseId, studentId])
  @@index([exerciseId])
  @@index([studentId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([gradedById])
  @@map("exercise_attempts")
}

model ActivityTracking {
  id         String        @id @default(uuid()) @db.Uuid
  attemptId  String        @map("attempt_id") @db.Uuid
  studentId  String        @map("student_id") @db.Uuid
  event      TrackingEvent
  metadata   Json          @default("{}")
  createdAt  DateTime      @default(now()) @map("created_at")

  attempt ExerciseAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([studentId])
  @@map("activity_tracking")
}

model SessionTracking {
  id              String    @id @default(uuid()) @db.Uuid
  attemptId       String    @map("attempt_id") @db.Uuid
  studentId       String    @map("student_id") @db.Uuid
  startedAt       DateTime  @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationSeconds Int?      @map("duration_seconds")
  lastPingAt      DateTime  @default(now()) @map("last_ping_at")

  attempt ExerciseAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  student User            @relation(fields: [studentId], references: [id])

  @@index([attemptId])
  @@index([studentId])
  @@map("session_tracking")
}

model StudentProgress {
  id             String    @id @default(uuid()) @db.Uuid
  attemptId      String    @unique @map("attempt_id") @db.Uuid
  studentId      String    @map("student_id")  @db.Uuid
  exerciseId     String    @map("exercise_id") @db.Uuid
  companyId      String?   @map("company_id")  @db.Uuid
  progressPct    Decimal   @default(0) @map("progress_pct") @db.Decimal(5,2)
  invoicesCount  Int       @default(0) @map("invoices_count")
  entriesCount   Int       @default(0) @map("entries_count")
  clientsCount   Int       @default(0) @map("clients_count")
  productsCount  Int       @default(0) @map("products_count")
  timeSpentMin   Int       @default(0) @map("time_spent_min")
  lastActivity   DateTime? @map("last_activity")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  attempt ExerciseAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([exerciseId])
  @@map("student_progress")
}

// ── Competencias (evidencia para acreditación SINAES) ───────────
//
// Catálogo de competencias que la plataforma puede EVIDENCIAR con datos
// reales (rúbricas + attempts). universityId NULL = plantilla global
// (catálogo base reutilizable); una universidad puede tener las suyas.
// Un Exercise declara qué competencias desarrolla vía ExerciseCompetency;
// opcionalmente cada criterio de rúbrica se ancla a una competencia para
// evidencia de grano fino. Ambos vínculos son ADITIVOS/opcionales: el
// contenido existente sigue funcionando sin tocar.
enum CompetencyArea {
  CONTABLE
  TRIBUTARIO
  FINANCIERO
  COSTOS
  AUDITORIA
  DATOS
  GESTION
}

model Competency {
  id           String         @id @default(uuid()) @db.Uuid
  universityId String?        @map("university_id") @db.Uuid   // NULL = plantilla global
  code         String                                          // 'C1', 'REGISTRO', ...
  name         String
  description  String?
  area         CompetencyArea @default(CONTABLE)
  level        Int?           // opcional: 1=Diplomado, 2=Bachillerato, 3=Licenciatura
  order        Int            @default(0)
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt      @map("updated_at")

  university University?           @relation(fields: [universityId], references: [id])
  exercises  ExerciseCompetency[]
  rubrics    ExerciseRubric[]

  @@unique([universityId, code])
  @@index([universityId])
  @@index([area])
  @@map("competencies")
}

// Join Exercise ↔ Competency: qué competencias mide un ejercicio y con
// qué peso relativo (para agregar el dominio por competencia por cohorte).
model ExerciseCompetency {
  id           String     @id @default(uuid()) @db.Uuid
  exerciseId   String     @map("exercise_id")   @db.Uuid
  competencyId String     @map("competency_id") @db.Uuid
  weight       Decimal    @default(1) @db.Decimal(5,2)

  exercise   Exercise   @relation(fields: [exerciseId],   references: [id], onDelete: Cascade)
  competency Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, competencyId])
  @@index([exerciseId])
  @@index([competencyId])
  @@map("exercise_competencies")
}

// ================================================================
//  BLOQUE 4 — EMPRESA SIMULADA
// ================================================================

model Company {
  id                 String       @id @default(uuid()) @db.Uuid
  // ── Fase 1: scoping multi-modo ─────────────────────────────
  // INDIVIDUAL → attemptId + studentId set (modelo histórico, 1:1).
  // GROUP      → exerciseId set, miembros via CompanyMembership;
  //              attemptId/studentId quedan NULL.
  attemptId          String?      @unique @map("attempt_id")  @db.Uuid
  studentId          String?      @map("student_id")          @db.Uuid
  exerciseId         String?      @map("exercise_id")         @db.Uuid
  mode               CompanyMode  @default(INDIVIDUAL)
  isCompanyEnabled   Boolean      @default(true) @map("is_company_enabled")
  name               String
  legalId            String       @map("legal_id")
  legalIdType        String       @default("02") @map("legal_id_type")  // 01 física, 02 jurídica
  economicActivity   String       @default("510101") @map("economic_activity")
  address            String?
  province           String?   // Provincia Hacienda: '1'=SJ, '2'=Alajuela... '7'=Limón
  canton             String?   // Canton code, e.g. '01'
  district           String?   // Distrito code, e.g. '01'
  phone              String?
  email              String?
  currency           String       @default("CRC")
  fiscalPeriodStart  DateTime?    @map("fiscal_period_start")
  fiscalPeriodEnd    DateTime?    @map("fiscal_period_end")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt      @map("updated_at")

  attempt           ExerciseAttempt?    @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  student           User?               @relation(fields: [studentId], references: [id])
  exercise          Exercise?           @relation("ExerciseCompanies", fields: [exerciseId], references: [id], onDelete: Cascade)
  memberships       CompanyMembership[]
  accountingPeriods AccountingPeriod[]
  accounts          Account[]
  journalEntries    JournalEntry[]
  clients           Client[]
  suppliers         Supplier[]
  products          Product[]
  invoices          Invoice[]
  payments          Payment[]
  activityLogs      ActivityLog[]
  bankAccounts      BankAccount[]
  bankStatements    BankStatement[]
  bankTransactions  BankTransaction[]
  journalSequence   JournalSequence?  @relation("JournalSequenceCompany")
  invoiceSequence   InvoiceSequence?  @relation("InvoiceSequenceCompany")
  journalLines      JournalLine[]     @relation("JournalLineCompany")
  fixedAssets       FixedAsset[]
  employees         Employee[]
  payrolls          Payroll[]
  purchaseInvoices  PurchaseInvoice[]
  partialPayments   PartialPayment[]
  retenciones       Retencion[]
  arPayments        ArPayment[]
  apPayments        ApPayment[]
  accountsReceivable AccountReceivable[]
  accountsPayable    AccountPayable[]
  inventoryLots      InventoryLot[]

  @@index([studentId])
  @@index([exerciseId])
  @@index([mode])
  @@index([isCompanyEnabled])
  @@map("companies")
}

// ── CompanyMembership (Fase 1) ──────────────────────────────────
// Solo se usa en companies modo GROUP. Para INDIVIDUAL la
// pertenencia se sigue derivando de Company.studentId.
model CompanyMembership {
  id        String      @id @default(uuid()) @db.Uuid
  companyId String      @map("company_id") @db.Uuid
  userId    String      @map("user_id")    @db.Uuid
  role      CompanyRole @default(MEMBER)
  joinedAt  DateTime    @default(now()) @map("joined_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId],   references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
  @@index([companyId])
  @@map("company_memberships")
}

model AccountingPeriod {
  id        String       @id @default(uuid()) @db.Uuid
  companyId String       @map("company_id") @db.Uuid
  name      String                           // "Enero 2026"
  type      PeriodType   @default(MONTHLY)
  startDate DateTime     @map("start_date")
  endDate   DateTime     @map("end_date")
  status    PeriodStatus @default(OPEN)
  closedAt  DateTime?    @map("closed_at")
  closedBy  String?      @map("closed_by") @db.Uuid
  notes     String?
  createdAt DateTime     @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, startDate, endDate])
  @@index([companyId])
  @@index([status])
  @@map("accounting_periods")
}

// ================================================================
//  BLOQUE 5 — MOTOR CONTABLE
// ================================================================

model Account {
  id            String        @id @default(uuid()) @db.Uuid
  companyId     String        @map("company_id") @db.Uuid
  code          String                               // "1.1.02.01"
  name          String
  type          AccountType
  subType       String?       @map("sub_type")
  parentId      String?       @map("parent_id") @db.Uuid
  level         Int           @default(1)            // 1-4
  isHeader      Boolean       @default(false) @map("is_header")
  normalBalance NormalBalance @map("normal_balance")
  description   String?
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")

  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent       Account?       @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     Account[]      @relation("AccountHierarchy")
  journalLines JournalLine[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([parentId])
  @@index([type])
  @@map("accounts")
}

model JournalEntry {
  id           String        @id @default(uuid()) @db.Uuid
  companyId    String        @map("company_id") @db.Uuid
  invoiceId    String?       @map("invoice_id") @db.Uuid
  paymentId    String?       @map("payment_id") @db.Uuid
  entryNumber  Int           @map("entry_number")       // consecutivo por empresa
  description  String
  entryDate    DateTime      @map("entry_date")  @db.Date
  reference    String?
  source       JournalSource @default(MANUAL)
  // ── Generic source link (extends invoiceId/paymentId for any business event) ──
  sourceType   String?       @map("source_type")          // 'sale','purchase','collection','payment','payroll','depreciation', etc.
  // String (no UUID) para soportar IDs compuestos en eventos N→1 como cobros
  // parciales sobre la misma factura: `${invoiceId}:${timestamp}`.
  sourceId     String?       @map("source_id")            // FK lógico al objeto de negocio que originó el asiento
  // ── Estado del asiento (HYBRID workflow) ──────────────────────
  //   CONFIRMED: default, afecta saldos. PENDING: pre-generado en modo
  //   HYBRID, no afecta saldos. REJECTED: descartado por el usuario.
  status       JournalEntryStatus @default(CONFIRMED)
  // Mantenemos isPending por backward-compat (== status == PENDING).
  // Se actualizan a la par.
  isPending    Boolean       @default(false) @map("is_pending")
  isReversed   Boolean       @default(false) @map("is_reversed")
  reversedById String?       @map("reversed_by") @db.Uuid
  createdById  String        @map("created_by")  @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at")

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id])
  payment      Payment?      @relation(fields: [paymentId], references: [id])
  createdBy    User          @relation(fields: [createdById], references: [id])
  lines        JournalLine[]

  @@unique([companyId, entryNumber])
  // Unique parcial: si `sourceType` y `sourceId` están presentes, NO puede
  // existir otro asiento con esa misma fuente. Postgres trata pares con
  // algún NULL como distintos, así que las filas legacy (NULL,NULL) no
  // colisionan. Es la red de seguridad final contra duplicados.
  @@unique([sourceType, sourceId], name: "uniq_source")
  @@index([companyId])
  @@index([entryDate])
  @@index([invoiceId])
  @@index([sourceType, sourceId])
  @@index([status])
  @@map("journal_entries")
}

model JournalLine {
  id          String   @id @default(uuid()) @db.Uuid
  entryId     String   @map("entry_id")   @db.Uuid
  accountId   String   @map("account_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  debit       Decimal  @default(0) @db.Decimal(15,2)
  credit      Decimal  @default(0) @db.Decimal(15,2)
  description String?

  entry   JournalEntry @relation(fields: [entryId],   references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])
  company Company      @relation("JournalLineCompany", fields: [companyId], references: [id])

  @@index([entryId])
  @@index([accountId])
  @@index([companyId, accountId])
  @@index([accountId, entryId])
  @@map("journal_lines")
}

// Atomic consecutive number per company — prevents race conditions
model JournalSequence {
  companyId  String  @id @map("company_id") @db.Uuid
  lastNumber Int     @default(0) @map("last_number")

  company Company @relation("JournalSequenceCompany", fields: [companyId], references: [id], onDelete: Cascade)

  @@map("journal_sequences")
}

// Atomic invoice consecutive number per company — same pattern as JournalSequence
model InvoiceSequence {
  companyId  String  @id @map("company_id") @db.Uuid
  lastNumber Int     @default(0) @map("last_number")

  company Company @relation("InvoiceSequenceCompany", fields: [companyId], references: [id], onDelete: Cascade)

  @@map("invoice_sequences")
}

