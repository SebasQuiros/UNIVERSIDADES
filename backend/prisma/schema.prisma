  statement       BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@index([statementId])
  @@map("bank_statement_lines")
}

model BankTransaction {
  id             String   @id @default(uuid()) @db.Uuid
  bankAccountId  String?  @map("bank_account_id") @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  date           DateTime
  description    String
  reference      String?
  amount         Decimal  @db.Decimal(15,2)
  type           String   // DEBIT, CREDIT
  source         String   @default("MANUAL") // INVOICE, PURCHASE, PAYROLL, MANUAL
  sourceId       String?  @map("source_id") @db.Uuid
  isReconciled   Boolean  @default(false) @map("is_reconciled")
  reconciledAt   DateTime? @map("reconciled_at")
  statementLineId String? @map("statement_line_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  bankAccount    BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([bankAccountId])
  @@map("bank_transactions")
}

model ActivityLog {
