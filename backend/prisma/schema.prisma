  totalRenta        Decimal  @default(0) @db.Decimal(15,2) @map("total_renta")
  journalEntryId    String?  @map("journal_entry_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   PayrollLine[]

  @@unique([companyId, period])
  @@index([companyId])
  @@map("payrolls")
}

model PayrollLine {
  id               String   @id @default(uuid()) @db.Uuid
  payrollId        String   @map("payroll_id") @db.Uuid
  employeeId       String   @map("employee_id") @db.Uuid

  // Ingresos
  salaryGross      Decimal  @db.Decimal(15,2) @map("salary_gross")
  overtime         Decimal  @default(0) @db.Decimal(15,2)
  bonus            Decimal  @default(0) @db.Decimal(15,2)
  totalGross       Decimal  @db.Decimal(15,2) @map("total_gross")

  // Deducciones trabajador
  ccssWorker       Decimal  @db.Decimal(15,2) @map("ccss_worker")
  rentaDeduccion   Decimal  @default(0) @db.Decimal(15,2) @map("renta_deduccion")
  otherDeductions  Decimal  @default(0) @db.Decimal(15,2) @map("other_deductions")
  totalDeductions  Decimal  @db.Decimal(15,2) @map("total_deductions")
  netSalary        Decimal  @db.Decimal(15,2) @map("net_salary")

  // Cargas patronales
  ccssPatrono      Decimal  @db.Decimal(15,2) @map("ccss_patrono")
  aguinaldo        Decimal  @db.Decimal(15,2)
  totalEmployerCost Decimal @db.Decimal(15,2) @map("total_employer_cost")

  // Breakdown JSON (for UI)
  breakdown        Json     @default("{}")

  payroll  Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([payrollId])
  @@index([employeeId])
  @@map("payroll_lines")
}

// ================================================================
//  BLOQUE 13 — FACTURAS DE COMPRA (CRÉDITO FISCAL IVA)
// ================================================================

model PurchaseInvoice {
  id             String   @id @default(uuid()) @db.Uuid
  companyId      String   @map("company_id")   @db.Uuid
  // Fase 4: opcional para soportar GROUP companies (sin attempt 1:1) y
  // mirror inter-company. INDIVIDUAL siempre lo trae set.
  attemptId      String?  @map("attempt_id")   @db.Uuid
  supplierName   String   @map("supplier_name")
  supplierCedula String?  @map("supplier_cedula")
  invoiceNumber  String   @map("invoice_number")
  date           DateTime
  subtotal       Decimal  @db.Decimal(15, 2)
  taxRate        Decimal  @default(0.13) @map("tax_rate")   @db.Decimal(5, 4)
  taxAmount      Decimal  @db.Decimal(15, 2)               @map("tax_amount")
  total          Decimal  @db.Decimal(15, 2)
  description    String?
  isAccepted     Boolean  @default(true)  @map("is_accepted")
  isPaid         Boolean  @default(false) @map("is_paid")
  paidAmount     Decimal  @default(0)     @map("paid_amount") @db.Decimal(15,2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attempt        ExerciseAttempt? @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  apPayments     ApPayment[]
  accountPayable AccountPayable?

  @@index([companyId])
  @@index([attemptId])
  @@map("purchase_invoices")
}

// ================================================================
//  BLOQUE 14b — IMPUESTO SOBRE LA RENTA (D-101)
// ================================================================

model PartialPayment {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  attemptId   String    @map("attempt_id") @db.Uuid
  fiscalYear  Int       @map("fiscal_year")
  quarter     Int       // 1, 2, 3, 4
  dueDate     DateTime  @map("due_date")
  amount      Decimal   @db.Decimal(15, 2)
  paidDate    DateTime? @map("paid_date")
  isPaid      Boolean   @default(false) @map("is_paid")
  createdAt   DateTime  @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([fiscalYear])
  @@map("partial_payments")
}

model Retencion {
  id              String    @id @default(uuid()) @db.Uuid
  companyId       String    @map("company_id") @db.Uuid
  attemptId       String    @map("attempt_id") @db.Uuid
  // 'SERVICIOS_PROFESIONALES' | 'ALQUILER' | 'DIVIDENDOS' | 'TRANSPORTE'
  type            String
  supplierName    String    @map("supplier_name")
  supplierCedula  String?   @map("supplier_cedula")
  grossAmount     Decimal   @db.Decimal(15, 2) @map("gross_amount")
  retentionRate   Decimal   @db.Decimal(5, 4)  @map("retention_rate")
  retentionAmount Decimal   @db.Decimal(15, 2) @map("retention_amount")
  netPaid         Decimal   @db.Decimal(15, 2) @map("net_paid")
  date            DateTime
  description     String?
  createdAt       DateTime  @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("retenciones")
}

// ================================================================
//  BLOQUE 14 — DECLARACIONES TRIBUTARIAS (PRÁCTICA TRIBU CR)
// ================================================================

enum TaxDeclarationType {
  D104_IVA        // Declaración IVA mensual
  D101_RENTA      // Declaración Renta anual personas jurídicas
  D103_RETENCION  // Retención en la fuente mensual
  D115_DIVIDENDOS // Dividendos y participaciones
}

enum TaxDeclarationStatus {
  DRAFT
  SUBMITTED
}

model TaxDeclaration {
  id          String               @id @default(uuid()) @db.Uuid
  userId      String               @map("user_id") @db.Uuid
  type        TaxDeclarationType
  period      String               // "2026-03" para D-104 | "2025-2026" para D-101
  status      TaxDeclarationStatus @default(DRAFT)
  formData    Json                 @map("form_data")   // casillas ingresadas
  result      Json                 @default("{}")       // cálculos finales
  referenceNo String?              @map("reference_no") // número simulado
  submittedAt DateTime?            @map("submitted_at")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt      @map("updated_at")

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments TaxAttachment[]

  @@index([userId])
  @@index([type])
  @@index([period])
  @@map("tax_declarations")
}

model TaxAttachment {
  id            String   @id @default(uuid()) @db.Uuid
  declarationId String   @map("declaration_id") @db.Uuid
  lineKey       String   @map("line_key")    // "ventas13", "gastosSueldos", etc.
  lineLabel     String   @map("line_label")  // etiqueta legible de la casilla
  fileName      String   @map("file_name")
  fileSize      Int      @map("file_size")   // bytes
  mimeType      String   @map("mime_type")
  fileData      String   @map("file_data")   @db.Text // base64
  uploadedAt    DateTime @default(now())     @map("uploaded_at")

  declaration TaxDeclaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)

  @@index([declarationId])
  @@index([lineKey])
  @@map("tax_attachments")
}

// ================================================================
//  BLOQUE 15 — AR/AP PAYMENTS (Phase 13)
// ================================================================

model ArPayment {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
  amount      Decimal  @db.Decimal(15,2)
  paymentDate DateTime @map("payment_date")
  method      String   @default("TRANSFER")  // CASH, TRANSFER, CHECK, CARD
  reference   String?
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice  Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([invoiceId])
  @@map("ar_payments")
}

model ApPayment {
  id                String   @id @default(uuid()) @db.Uuid
  companyId         String   @map("company_id")          @db.Uuid
  purchaseInvoiceId String   @map("purchase_invoice_id") @db.Uuid
  amount            Decimal  @db.Decimal(15,2)
  paymentDate       DateTime @map("payment_date")
  method            String   @default("TRANSFER")
  reference         String?
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")

  company         Company         @relation(fields: [companyId],         references: [id], onDelete: Cascade)
  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([purchaseInvoiceId])
  @@map("ap_payments")
}

// ================================================================
//  BLOQUE 16 — CUENTAS POR COBRAR / POR PAGAR (Tablas reales)
//
//  Espejo persistente del saldo de cada factura. Lo poblamos desde
//  BusinessEventsService.recordSale / recordPurchase y lo reducimos
//  desde recordCollection / recordPayment.
//
//  Las APIs que ya derivan AR/AP en runtime (aging, statement) siguen
//  funcionando — estas tablas son una vista materializada para tener
//  un saldo confiable y un punto único de verdad.
// ================================================================

enum ARStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum APStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

model AccountReceivable {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id")  @db.Uuid
  customerId  String?  @map("customer_id") @db.Uuid     // null si la factura no tenía Client (ventas a contado)
  invoiceId   String   @unique @map("invoice_id") @db.Uuid
  total       Decimal  @db.Decimal(15, 2)
  balance     Decimal  @db.Decimal(15, 2)
  status      ARStatus @default(PENDING)
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  company  Company  @relation(fields: [companyId],  references: [id], onDelete: Cascade)
  customer Client?  @relation(fields: [customerId], references: [id])
  invoice  Invoice  @relation(fields: [invoiceId],  references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([customerId])
  @@map("accounts_receivable")
}

model AccountPayable {
  id                String   @id @default(uuid()) @db.Uuid
  companyId         String   @map("company_id")          @db.Uuid
  supplierName      String   @map("supplier_name")       // PurchaseInvoice usa nombre denormalizado
  supplierCedula    String?  @map("supplier_cedula")
  purchaseInvoiceId String   @unique @map("purchase_invoice_id") @db.Uuid
  total             Decimal  @db.Decimal(15, 2)
  balance           Decimal  @db.Decimal(15, 2)
  status            APStatus @default(PENDING)
  dueDate           DateTime? @map("due_date")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt      @map("updated_at")

  company         Company         @relation(fields: [companyId],         references: [id], onDelete: Cascade)
  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([supplierName])
  @@map("accounts_payable")
}
